# Copy to `.env` for local development. The values below match docker-compose.yml.
# Production (Dokku) sets DATABASE_URL automatically when you link the postgres
# service — see README.
DATABASE_URL="postgresql://bakery:bakery@localhost:5432/bakery_popup_dev?schema=public"

# PIN required to unlock the /menu admin page and order-status controls.
# Anyone with this PIN can edit the menu and advance orders.
HOST_PIN="0000"

# Optional — strong random string used to sign the host session cookie. If
# unset, the cookie secret is derived from HOST_PIN, which means changing the
# PIN logs out every active host session. Set this in production for a stable
# session secret independent of the PIN.
# HOST_SESSION_SECRET="generate-a-random-32+-char-string-here"
